#!/bin/bash
# config_callback：配置后回调（重启服务使新配置生效）
set -e

APP_NAME="com.dustinky.agentbackup"
APP_DATA_DIR="/vol3/@appdata/${APP_NAME}"
SERVICE_PORT=12083
LOG_DIR="${APP_DATA_DIR}/logs"
SERVER_LOG="${LOG_DIR}/server.log"

mkdir -p "${LOG_DIR}" 2>/dev/null || true
touch "${SERVER_LOG}" 2>/dev/null || true

echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] config_callback: 配置后重启" | tee -a "${SERVER_LOG}"

# 调用 main restart（v1.0.20 修：路径与 cmd/main 一致，TRIM_APPDEST 优先）
APP_INSTALL_DIR="${TRIM_APPDEST:-/vol3/@appcenter/${APP_NAME}}"
if [ -x "${APP_INSTALL_DIR}/cmd/main" ]; then
    "${APP_INSTALL_DIR}/cmd/main" restart 2>&1 | tee -a "${SERVER_LOG}" || true
else
    # 兜底 pkill
    pkill -9 -f "node.*${APP_NAME}.*server" 2>/dev/null || true
    fuser -k -9 "${SERVICE_PORT}/tcp" 2>/dev/null || true
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] config_callback: OK" | tee -a "${SERVER_LOG}"
exit 0
